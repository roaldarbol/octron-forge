{
  "$schema": "https://json-schema.org/draft-07/schema",
  "$id": "https://schemas.conda.io/menuinst-1.schema.json",
  "menu_name": "OCTRON",
  "menu_items": [
    {
      "name": "OCTRON",
      "description": "OCTRON - segmentation and tracking for animal behavior quantification",
      "icon": "{{ MENU_DIR }}/octron.{{ ICON_EXT }}",
      "command": ["octron-gui"],
      "activate": true,
      "terminal": false,
      "platforms": {
        "win": {
          "desktop": true,
          "menu": true,
          "command": ["{{ PREFIX }}\\pythonw.exe", "-c", "from octron.main import octron_gui; octron_gui()"]
        },
        "linux": {
          "Categories": ["Science", "Education"]
        },
        "osx": {
          "CFBundleName": "OCTRON",
          "CFBundleDisplayName": "OCTRON"
        }
      }
    }
  ]
}
